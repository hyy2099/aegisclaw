# 币安 API 配置
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
BINANCE_TESTNET=false

# Telegram 配置（可选，用于接收通知）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# 安全配置
# 每日最大交易次数
MAX_DAILY_TRADES=10
# 最大价格滑点（1%）
MAX_PRICE_SLIPPAGE=0.01

# 策略配置
# 资金费率套利阈值（0.01%）
FUNDING_RATE_THRESHOLD=0.0001
# 最小套利利润（0.1%）
MIN_ARBITRAGE_PROFIT=0.001
# Launchpool 最小参与金额（USDT）
MIN_LAUNCHPOOL_AMOUNT=10.0
# Dust Sweeper 最小兑换阈值（USDT 等值）
MIN_DUST_THRESHOLD=10.0
